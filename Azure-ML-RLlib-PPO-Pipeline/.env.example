# ============================================================
# Plato RL Azure — Configuration
# ============================================================
# Copy this file to .env and fill in your Azure details.
# Run 'plato check' to verify your configuration.
# ============================================================

# REQUIRED: Your Azure subscription ID
# Find it with: az account show --query id -o tsv
AZURE_SUBSCRIPTION_ID=

# Azure resource group (created automatically)
AZURE_RESOURCE_GROUP=plato-rl-rg

# Azure region (pick one close to you)
# Options: eastus, westus2, westeurope, southeastasia, etc.
AZURE_LOCATION=eastus

# Azure ML workspace name (created automatically)
AZURE_WORKSPACE_NAME=plato-rl-ws

# Compute cluster settings
AZURE_COMPUTE_NAME=plato-compute
AZURE_COMPUTE_VM_SIZE=Standard_D4s_v3
AZURE_COMPUTE_MIN_NODES=0
AZURE_COMPUTE_MAX_NODES=2

# AML environment name
AZURE_ENVIRONMENT_NAME=plato-rl-env

# Training parameters
TRAINING_ITERATIONS=10
TRAIN_BATCH_SIZE=4000

# Hyperparameter tuning
NUM_TUNE_SAMPLES=2

# Deployment
AZURE_ENDPOINT_NAME=plato-agent-endpoint
